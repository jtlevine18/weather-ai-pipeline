# ---------------------------------------------------------------
# Weather AI Pipeline — Environment Variables
# ---------------------------------------------------------------
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ---------------------------------------------------------------

# Required — Claude advisory generation + translation to local languages
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Required — Tomorrow.io cross-validation for anomaly healing
# Free tier: 500 calls/day — https://app.tomorrow.io/signup
TOMORROW_IO_API_KEY=

# Required — PostgreSQL database connection
# Free tier: https://neon.tech (serverless Postgres, no credit card)
DATABASE_URL=

# Required — JWT signing key for API authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# ---------------------------------------------------------------
# Region configuration (optional — defaults to Southern India)
# ---------------------------------------------------------------
# REGION_NAME=Southern India
# TIMEZONE=Asia/Kolkata

# ---------------------------------------------------------------
# HF Inference — Llama 3.1 8B personalization + translation
# ---------------------------------------------------------------
# Free serverless tier: set HF_TOKEN only (rate-limited, good for demos)
# Dedicated endpoint:   also set HF_ENDPOINT_URL (paid, high throughput)
# If HF_TOKEN is unset, falls back to Claude for advisory generation.
# HF_TOKEN=hf_...
# HF_ENDPOINT_URL=https://xyz123.endpoints.huggingface.cloud
# HF_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct

# ---------------------------------------------------------------
# No key needed
# ---------------------------------------------------------------
# NASA POWER  — fully open, no authentication
# Open-Meteo  — fully open, no authentication
# NeuralGCM   — GCS public bucket, no authentication
